{
  "name": "zundamons-kitchen-v2",
  "version": "1.0.0",
  "description": "Clean, structured transfer of Zundamon's kItchen",
  "private": true,
  "scripts": {
    "lint": "npm run lint:stylua && npm run lint:selene",
    "lint:stylua": "npx @johnnymorganz/stylua-bin --check src",
    "lint:selene": "selene src",
    "rojo:build": "rojo build default.project.json -o build/Zundamons-kItchen.rbxl",
